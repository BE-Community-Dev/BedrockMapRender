<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BedrockRender.Avalonia.BedrockMapStatusOverlay">
  <Border Padding="10,8"
          CornerRadius="8"
          Background="#D2202020">
    <StackPanel Spacing="2">
      <TextBlock x:Name="CoordinateText" Text="X: --, Z: --" />
      <TextBlock x:Name="ScaleText" Text="缩放: 100%" />
      <TextBlock x:Name="SizeText" Text="图像: --" />
    </StackPanel>
  </Border>
</UserControl>